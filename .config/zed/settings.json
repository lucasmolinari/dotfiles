// documentation: https://zed.dev/docs/configuring-zed
{
  "diff_view_style": "split",
  "cli_default_open_behavior": "existing_window",
  "git_panel": {
    "dock": "right",
    "sort_by_path": true,
  },
  "icon_theme": "Material Icon Theme",
  "agent": {
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1",
      "enable_thinking": false,
    },
    "dock": "right",
    "tool_permissions": {
      "tools": {
        "edit_file": {
          "always_allow": [
            {
              "pattern": "^src/app/shared/services/",
            },
          ],
        },
        "terminal": {
          "default": "allow",
        },
      },
    },
    "default_profile": "write",
    "default_model": {
      "enable_thinking": false,
      "provider": "copilot_chat",
      "model": "gpt-4o",
    },
    "model_parameters": [
      {
        "temperature": 0.2,
      },
    ],
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light Soft",
    "dark": "Gruvbox Dark Hard",
  },

  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "vim": {
    "use_system_clipboard": "on_yank",
  },

  "minimap": {
    "show": "auto",
    "current_line_highlight": "line",
  },

  "ensure_final_newline_on_save": false,
  "inlay_hints": {
    "enabled": false,
  },
  "inline_code_actions": true,
  "diagnostics": {
    "inline": {
      "enabled": true,
      "update_debounce_ms": 450,
    },
  },
  "scrollbar": {
    "show": "never",
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
    "selections_menu": false,
  },
  "tabs": {
    "file_icons": true,
    "git_status": false,
    "show_diagnostics": "errors",
  },
  "status_bar": {
    "active_language_button": false,
  },
  "file_finder": {
    "modal_max_width": "medium",
  },
  "git": {
    "inline_blame": {
      "enabled": false,
      "delay_ms": 500,
    },
  },
  "terminal": {
    "copy_on_select": true,
    "dock": "right",
  },
  "project_panel": {
    "dock": "left",
    "button": false,
    "git_status_indicator": true,
    "git_status": true,
  },
  "semantic_tokens": "combined",
  "collaboration_panel": { "dock": "left", "button": false },
  "outline_panel": { "dock": "left", "button": false },
  "search": { "button": false },
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
  },
  "context_servers": {
    "primeng": {
      "command": "npx",
      "args": ["-y", "@primeng/mcp"],
      "env": {},
    },
  },
}
